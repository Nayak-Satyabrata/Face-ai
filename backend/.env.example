# Backend — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string (local default shown)
MONGODB_URI=mongodb://127.0.0.1:27017/face_attendance

# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/face_attendance

# Server port
PORT=5000

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development
